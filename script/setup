#!/usr/bin/env bash
#
# Defender for Servers（Private VM + Azure Firewall）一式をデプロイする。
#
# 前提:
#   - Azure CLI (az) がインストール済み
#   - `az login` 済み
#
# 環境変数で上書き可能（括弧内は既定値）:
#   LOCATION            デプロイ先リージョン        (japaneast)
#   RESOURCE_GROUP      作成するリソースグループ名  (rg-defender-priv-vm)
#   NAME_PREFIX         リソース名プレフィックス    (dfs-priv)
#   ADMIN_USERNAME      VM 管理者名                 (azureuser)
#   SSH_KEY_PATH        SSH 秘密鍵パス（.pub を公開鍵として使用） (~/.ssh/dfs_priv_vm)
#   WIN_ADMIN_PASSWORD  Windows VM 管理者パスワード (未指定なら生成しファイル保存・再利用)
#   WIN_PASSWORD_FILE   生成パスワードの保存先          (<SSH_KEY_PATH>_win_password.txt)
#   SUBSCRIPTION_ID     対象サブスクリプション ID   (現在の az 既定)
#   VM_SIZE             VM サイズ                   (Standard_D2s_v3)
#   ENABLE_DEFENDER     Defender for Servers P2 を有効化 (true) ※Portal 設定なら false
#                       ※有効化前のプラン状態を保存し destroy でロールバック可能にする
#   DFS_STATE_DIR       ロールバック状態の保存先         (~/.dfs-priv)
#   DEPLOY_LINUX_VM     Ubuntu 24.04 VM をデプロイ  (true)
#   DEPLOY_WINDOWS_VM   WS2025 Azure Edition VM をデプロイ (true)
#   AUTO_APPROVE        確認プロンプトをスキップ    (false)
#
set -euo pipefail

LOCATION="${LOCATION:-japaneast}"
RESOURCE_GROUP="${RESOURCE_GROUP:-rg-defender-priv-vm}"
NAME_PREFIX="${NAME_PREFIX:-dfs-priv}"
ADMIN_USERNAME="${ADMIN_USERNAME:-azureuser}"
SSH_KEY_PATH="${SSH_KEY_PATH:-$HOME/.ssh/dfs_priv_vm}"
WIN_ADMIN_PASSWORD="${WIN_ADMIN_PASSWORD:-}"
WIN_PASSWORD_FILE="${WIN_PASSWORD_FILE:-${SSH_KEY_PATH}_win_password.txt}"
DFS_STATE_DIR="${DFS_STATE_DIR:-$HOME/.dfs-priv}"
SUBSCRIPTION_ID="${SUBSCRIPTION_ID:-}"
VM_SIZE="${VM_SIZE:-Standard_D2s_v3}"
ENABLE_DEFENDER="${ENABLE_DEFENDER:-true}"
DEPLOY_LINUX_VM="${DEPLOY_LINUX_VM:-true}"
DEPLOY_WINDOWS_VM="${DEPLOY_WINDOWS_VM:-true}"
AUTO_APPROVE="${AUTO_APPROVE:-false}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_DIR="$SCRIPT_DIR/../infra"
TEMPLATE_FILE="$INFRA_DIR/main.bicep"
DEPLOYMENT_NAME="dfs-priv-$(date +%Y%m%d%H%M%S)"

log()  { printf '\033[1;34m[setup]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; }

# --- 事前チェック ---
command -v az >/dev/null 2>&1 || { err "Azure CLI (az) が見つかりません。"; exit 1; }

if ! az account show >/dev/null 2>&1; then
  err "Azure にログインしていません。先に 'az login' を実行してください。"
  exit 1
fi

if [[ -n "$SUBSCRIPTION_ID" ]]; then
  log "サブスクリプションを設定: $SUBSCRIPTION_ID"
  az account set --subscription "$SUBSCRIPTION_ID"
fi
CURRENT_SUB="$(az account show --query '[name, id]' -o tsv | paste -sd' / ' -)"
SUB_ID="$(az account show --query id -o tsv)"
DEFENDER_STATE_FILE="$DFS_STATE_DIR/defender-pricing-${SUB_ID}.env"

# --- Defender プラン変更前の状態を保存（destroy でロールバックするため）---
# ENABLE_DEFENDER=true のときだけ Bicep がプランを変更するので、その前に現状を控える。
# 既に保存済みなら上書きしない（= 最初の setup 時点の「真の元状態」を保持）。
if [[ "$ENABLE_DEFENDER" == "true" ]]; then
  mkdir -p "$DFS_STATE_DIR"
  if [[ -f "$DEFENDER_STATE_FILE" ]]; then
    log "Defender 変更前状態は保存済み: ${DEFENDER_STATE_FILE}（上書きしません）"
  else
    orig_tier=""; orig_sub=""
    read -r orig_tier orig_sub < <(az security pricing show --name VirtualMachines --query '[pricingTier, subPlan]' -o tsv 2>/dev/null || true)
    if [[ -n "$orig_tier" ]]; then
      { printf 'tier=%s\n' "$orig_tier"; printf 'subplan=%s\n' "$orig_sub"; } > "$DEFENDER_STATE_FILE"
      log "Defender 変更前状態を保存: tier=$orig_tier subplan=${orig_sub:-(none)} -> $DEFENDER_STATE_FILE"
    else
      warn "Defender 現在状態を取得できず、ロールバック用の保存をスキップしました。"
    fi
  fi
fi

# --- SSH 鍵（Linux 用、無ければ生成）---
if [[ ! -f "${SSH_KEY_PATH}.pub" ]]; then
  log "SSH 鍵が無いため生成します: ${SSH_KEY_PATH}"
  mkdir -p "$(dirname "$SSH_KEY_PATH")"
  ssh-keygen -t ed25519 -f "$SSH_KEY_PATH" -N "" -C "$ADMIN_USERNAME@dfs-priv" >/dev/null
fi
SSH_PUBLIC_KEY="$(cat "${SSH_KEY_PATH}.pub")"
export SSH_PUBLIC_KEY

# --- Windows 管理者パスワード（再実行のべき等性のためファイルに保存して再利用）---
# 既存 VM に異なるパスワードを再適用すると Azure が拒否するため、毎回同じ値を使う。
if [[ "$DEPLOY_WINDOWS_VM" == "true" && -z "$WIN_ADMIN_PASSWORD" ]]; then
  if [[ -f "$WIN_PASSWORD_FILE" ]]; then
    WIN_ADMIN_PASSWORD="$(cat "$WIN_PASSWORD_FILE")"
    log "既存の Windows 管理者パスワードを再利用: $WIN_PASSWORD_FILE"
  else
    WIN_ADMIN_PASSWORD="$(openssl rand -base64 18)Aa1!"
    ( umask 077; printf '%s\n' "$WIN_ADMIN_PASSWORD" > "$WIN_PASSWORD_FILE" )
    warn "Windows 管理者パスワードを生成し保存しました（再実行で再利用）: $WIN_PASSWORD_FILE"
    warn "  user=${ADMIN_USERNAME}  password=${WIN_ADMIN_PASSWORD}"
  fi
fi
export WIN_ADMIN_PASSWORD

# --- 確認 ---
cat <<EOF

================ デプロイ内容 ================
  サブスクリプション : $CURRENT_SUB
  リソースグループ   : $RESOURCE_GROUP
  リージョン         : $LOCATION
  名前プレフィックス : $NAME_PREFIX
  VM サイズ          : $VM_SIZE
  Linux VM (24.04)   : $DEPLOY_LINUX_VM
  Windows VM (2025)  : $DEPLOY_WINDOWS_VM
  SSH 公開鍵         : ${SSH_KEY_PATH}.pub
  Defender for Servers Plan 2 : $ENABLE_DEFENDER
=============================================
EOF

if [[ "$ENABLE_DEFENDER" == "true" ]]; then
  warn "Defender for Servers Plan 2 は【サブスクリプション全体】で有効化され、課金が発生します。"
fi

if [[ "$AUTO_APPROVE" != "true" ]]; then
  read -r -p "続行しますか? [y/N] " ans
  [[ "$ans" =~ ^[Yy]$ ]] || { log "中止しました。"; exit 0; }
fi

PARAMS=(
  location="$LOCATION"
  namePrefix="$NAME_PREFIX"
  resourceGroupName="$RESOURCE_GROUP"
  adminUsername="$ADMIN_USERNAME"
  sshPublicKey="$SSH_PUBLIC_KEY"
  adminPassword="$WIN_ADMIN_PASSWORD"
  vmSize="$VM_SIZE"
  enableDefenderForServersPlan="$ENABLE_DEFENDER"
  deployLinuxVm="$DEPLOY_LINUX_VM"
  deployWindowsVm="$DEPLOY_WINDOWS_VM"
)

# --- デプロイ ---
log "Bicep を検証中..."
az deployment sub validate \
  --name "$DEPLOYMENT_NAME" \
  --location "$LOCATION" \
  --template-file "$TEMPLATE_FILE" \
  --parameters "${PARAMS[@]}" \
  >/dev/null
log "検証 OK。"

log "デプロイを開始します（Azure Firewall の作成に数分かかります）..."
az deployment sub create \
  --name "$DEPLOYMENT_NAME" \
  --location "$LOCATION" \
  --template-file "$TEMPLATE_FILE" \
  --parameters "${PARAMS[@]}" \
  --output table

log "完了しました。"
log "Defender for Cloud -> Inventory で対象 VM が Healthy になるまで数十分かかる場合があります。"
