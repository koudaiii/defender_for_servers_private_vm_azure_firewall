#!/usr/bin/env bash
#
# デプロイ済み環境の確認スクリプト（読み取り専用 / リソースは変更しない）。
#   レイヤー1: Azure リソースの整合（Firewall / Route / VM / Public IP 無し）
#   レイヤー2: VM 内から MDE 疎通テスト（az vm run-command 経由・受信接続不要）
#             + www.microsoft.com への通信が「遮断される」ことのネガティブテスト
#
# 前提: az CLI / az login 済み / setup でデプロイ済み
#
# 環境変数:
#   RESOURCE_GROUP   リソースグループ名         (rg-defender-priv-vm)
#   NAME_PREFIX      リソース名プレフィックス   (dfs-priv)
#   SUBSCRIPTION_ID  対象サブスクリプション     (現在の az 既定)
#   SKIP_RUNCMD      true でレイヤー2を省略     (false)
#
set -euo pipefail

RESOURCE_GROUP="${RESOURCE_GROUP:-rg-defender-priv-vm}"
NAME_PREFIX="${NAME_PREFIX:-dfs-priv}"
SUBSCRIPTION_ID="${SUBSCRIPTION_ID:-}"
SKIP_RUNCMD="${SKIP_RUNCMD:-false}"

LINUX_VM="${NAME_PREFIX}-linux"
WIN_VM="${NAME_PREFIX}-win"

log()  { printf '\033[1;34m[verify]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[ok]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; }

command -v az >/dev/null 2>&1 || { err "Azure CLI (az) が見つかりません。"; exit 1; }
az account show >/dev/null 2>&1 || { err "先に 'az login' を実行してください。"; exit 1; }
[[ -n "$SUBSCRIPTION_ID" ]] && az account set --subscription "$SUBSCRIPTION_ID"

fail=0

assert_eq() {
  local desc="$1" expected="$2" actual="$3"
  if [[ "$actual" == "$expected" ]]; then ok "$desc = $actual"; else err "$desc: 期待 '$expected' / 実際 '$actual'"; fail=1; fi
}
assert_nonempty() {
  local desc="$1" actual="$2"
  if [[ -n "$actual" && "$actual" != "null" ]]; then ok "$desc = $actual"; else err "$desc が空です"; fail=1; fi
}

# ============ レイヤー1: Azure リソースの整合 ============
log "レイヤー1: Azure リソースを確認..."

fw_state="$(az network firewall show -g "$RESOURCE_GROUP" -n "${NAME_PREFIX}-afw" --query provisioningState -o tsv 2>/dev/null || true)"
assert_eq "Firewall provisioningState" "Succeeded" "$fw_state"

fw_ip="$(az network firewall show -g "$RESOURCE_GROUP" -n "${NAME_PREFIX}-afw" --query 'ipConfigurations[0].privateIPAddress' -o tsv 2>/dev/null || true)"
assert_nonempty "Firewall Private IP" "$fw_ip"

route_hop="$(az network route-table route show -g "$RESOURCE_GROUP" --route-table-name "${NAME_PREFIX}-rt" -n to-internet-via-firewall --query nextHopIpAddress -o tsv 2>/dev/null || true)"
assert_eq "デフォルトルート nextHop = Firewall IP" "$fw_ip" "$route_hop"

rcg_count="$(az network firewall policy rule-collection-group list --policy-name "${NAME_PREFIX}-afwpolicy" -g "$RESOURCE_GROUP" --query 'length(@)' -o tsv 2>/dev/null || echo 0)"
if [[ "${rcg_count:-0}" -ge 1 ]]; then ok "ルールコレクショングループ数 = $rcg_count"; else err "ルールコレクショングループが不足: $rcg_count"; fail=1; fi

# 存在する VM を検出
vms=()
az vm show -g "$RESOURCE_GROUP" -n "$LINUX_VM" >/dev/null 2>&1 && vms+=("$LINUX_VM")
az vm show -g "$RESOURCE_GROUP" -n "$WIN_VM"   >/dev/null 2>&1 && vms+=("$WIN_VM")
if [[ "${#vms[@]}" -eq 0 ]]; then err "VM が見つかりません（${LINUX_VM} / ${WIN_VM}）"; fail=1; fi

for vm in "${vms[@]}"; do
  state="$(az vm show -g "$RESOURCE_GROUP" -n "$vm" --query provisioningState -o tsv 2>/dev/null || true)"
  assert_eq "VM[$vm] provisioningState" "Succeeded" "$state"
  pip="$(az vm list-ip-addresses -g "$RESOURCE_GROUP" -n "$vm" --query '[0].virtualMachine.network.publicIpAddresses' -o tsv 2>/dev/null || true)"
  assert_eq "VM[$vm] Public IP なし" "" "$pip"
done

# ============ レイヤー2: VM 内から疎通テスト ============
if [[ "$SKIP_RUNCMD" == "true" ]]; then
  warn "SKIP_RUNCMD=true のためレイヤー2をスキップします。"
  echo
  if [[ "$fail" -eq 0 ]]; then ok "確認完了（レイヤー1のみ）。"; else err "確認に失敗があります。"; fi
  exit "$fail"
fi

# Linux: MDE 疎通 + www.microsoft.com 遮断（ネガティブ）
# 変数/コマンド置換はリモート VM 上で展開させるため、意図的にシングルクォート（ローカル展開しない）。
# shellcheck disable=SC2016
LINUX_SCRIPT='
set +e
if command -v mdatp >/dev/null 2>&1; then
  echo "MDATP_FOUND=yes"
  echo "HEALTHY=$(mdatp health --field healthy 2>/dev/null)"
  echo "ORGID=$(mdatp health --field org_id 2>/dev/null)"
  echo "--- mdatp connectivity test ---"
  mdatp connectivity test 2>&1
else
  echo "MDATP_FOUND=no"
fi
echo "--- negative: www.microsoft.com (should FAIL) ---"
code=$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" https://www.microsoft.com 2>/dev/null)
rc=$?
echo "CURL_RC=$rc HTTP_CODE=$code"
if [ "$rc" -ne 0 ] || [ "$code" = "000" ]; then echo "WWW_BLOCKED=yes"; else echo "WWW_BLOCKED=no"; fi
'

# Windows: MDE(Sense) + www.microsoft.com 遮断（ネガティブ）
# 注意: Test-NetConnection -Port 443 は TCP ハンドシェイクの成否しか見ない。
#       Azure Firewall のアプリケーションルールは TCP ハンドシェイクを先に成立させ、
#       TLS の SNI / HTTP ホストを受け取った段階で Deny するため、TCP は必ず成功する
#       （= 偽陰性）。Linux 側の curl と同様に、実際の HTTP/HTTPS リクエストで遮断を判定する。
# shellcheck disable=SC2016
WIN_SCRIPT='
$ErrorActionPreference = "SilentlyContinue"
$svc = (Get-Service Sense).Status
"SENSE_STATUS=$svc"
$e = Get-WinEvent -LogName "Microsoft-Windows-SENSE/Operational" -MaxEvents 40 | Where-Object Id -eq 4 | Select-Object -First 1
if ($e) { "EVENT4_FOUND=yes" } else { "EVENT4_FOUND=no" }
"--- negative: www.microsoft.com (should FAIL) ---"
# 参考: TCP 到達性（アプリルール配下では Firewall がハンドシェイクを受けるため True になりうる）
$tcp = Test-NetConnection www.microsoft.com -Port 443 -WarningAction SilentlyContinue
"WWW_TCP_SUCCESS=$($tcp.TcpTestSucceeded)"
# ハードチェック: 実際の HTTPS リクエストが遮断されるか（curl 相当）
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
$blocked = $false
try {
  $resp = Invoke-WebRequest -Uri "https://www.microsoft.com" -UseBasicParsing -TimeoutSec 15 -MaximumRedirection 0
  "WWW_HTTP_STATUS=$($resp.StatusCode)"
} catch {
  $blocked = $true
  "WWW_HTTP_ERROR=$($_.Exception.Message)"
}
if ($blocked) { "WWW_BLOCKED=yes" } else { "WWW_BLOCKED=no" }
'

run_cmd() {
  local vm="$1" cmdid="$2" script="$3"
  az vm run-command invoke -g "$RESOURCE_GROUP" -n "$vm" --command-id "$cmdid" \
    --scripts "$script" --query 'value[0].message' -o tsv 2>/dev/null || true
}

check_mde_output() {
  local vm="$1" out="$2"
  if grep -q "MDATP_FOUND=yes\|EVENT4_FOUND=yes\|SENSE_STATUS=Running" <<<"$out"; then
    if grep -q "HEALTHY=true\|EVENT4_FOUND=yes" <<<"$out"; then
      ok "VM[$vm] MDE 疎通: 良好"
    else
      warn "VM[$vm] MDE は導入済みだが疎通確証が弱い（オンボーディング進行中の可能性）"
    fi
  else
    warn "VM[$vm] MDE 未展開の可能性（プラン自動展開は数十分かかる）。時間をおいて再実行を。"
  fi
  # ネガティブテスト（既定 Deny の確認）はハードチェック
  if grep -q "WWW_BLOCKED=yes" <<<"$out"; then
    ok "VM[$vm] www.microsoft.com への通信は遮断（既定 Deny が機能）"
  elif grep -q "WWW_BLOCKED=no" <<<"$out"; then
    err "VM[$vm] www.microsoft.com に到達できてしまいました（Deny が機能していません）"
    fail=1
  else
    warn "VM[$vm] www.microsoft.com 遮断テストの結果を取得できませんでした"
  fi
}

for vm in "${vms[@]}"; do
  log "レイヤー2: VM[$vm] で run-command 実行中（数十秒かかります）..."
  if [[ "$vm" == "$LINUX_VM" ]]; then
    out="$(run_cmd "$vm" RunShellScript "$LINUX_SCRIPT")"
  else
    out="$(run_cmd "$vm" RunPowerShellScript "$WIN_SCRIPT")"
  fi
  printf '%s\n' "----- VM[$vm] 出力 -----"
  printf '%s\n' "$out"
  printf '%s\n' "------------------------"
  check_mde_output "$vm" "$out"
done

# ============ レイヤー4: Firewall 診断ログ（Log Analytics）============
# 構造化ログ（AZFWNetworkRule / AZFWApplicationRule）で許可/拒否を裏取りする。
# ★ログのインジェストには数分のラグがあるため、ここは参考扱い（warn）。
LAW_NAME="${NAME_PREFIX}-law"
ws_guid="$(az monitor log-analytics workspace show -g "$RESOURCE_GROUP" -n "$LAW_NAME" --query customerId -o tsv 2>/dev/null || true)"

if [[ -z "$ws_guid" ]]; then
  warn "Log Analytics ワークスペース ($LAW_NAME) が見つかりません（enableFirewallDiagnostics=false の可能性）。レイヤー4をスキップ。"
else
  log "レイヤー4: Firewall 診断ログを照会（ワークスペース $LAW_NAME / ログ反映に数分かかる場合あり）..."

  run_kql() {
    az monitor log-analytics query --workspace "$ws_guid" --analytics-query "$1" -o tsv 2>/dev/null || true
  }

  # 直近1時間の Network Rule 許可/拒否サマリ
  net_summary="$(run_kql 'AZFWNetworkRule | where TimeGenerated > ago(1h) | summarize c=count() by Action | order by Action asc')"
  if [[ -n "$net_summary" ]]; then
    ok "AZFWNetworkRule（直近1h）Action 別件数:"
    printf '%s\n' "$net_summary"
  else
    warn "AZFWNetworkRule にまだログがありません（インジェスト待ち or 通信未発生）。"
  fi

  # www.microsoft.com への Deny が記録されているか（ネガティブテストの裏取り）
  deny_hits="$(run_kql 'AZFWNetworkRule | where TimeGenerated > ago(1h) and Action == "Deny" | take 5 | project TimeGenerated, SourceIp, DestinationIp, DestinationPort')"
  if [[ -n "$deny_hits" ]]; then
    ok "Deny ログを確認（既定 Deny がログにも記録されている）:"
    printf '%s\n' "$deny_hits"
  else
    warn "Deny ログは未取得（ラグの可能性）。数分後に再実行で確認できます。"
  fi

  # Application Rule（Linux: config.edge.skype.com）の許可
  app_hits="$(run_kql 'AZFWApplicationRule | where TimeGenerated > ago(1h) | take 5 | project TimeGenerated, SourceIp, Fqdn, Action')"
  if [[ -n "$app_hits" ]]; then
    ok "AZFWApplicationRule（直近1h）:"
    printf '%s\n' "$app_hits"
  else
    warn "AZFWApplicationRule にまだログがありません（Linux 未デプロイ or ラグ）。"
  fi
fi

echo
if [[ "$fail" -eq 0 ]]; then ok "確認完了。"; else err "確認に失敗があります。"; fi
exit "$fail"
