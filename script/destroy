#!/usr/bin/env bash
#
# デプロイしたリソースを削除する。
#
# 環境変数:
#   RESOURCE_GROUP    削除するリソースグループ名 (rg-defender-priv-vm)
#   SUBSCRIPTION_ID   対象サブスクリプション ID  (現在の az 既定)
#   RESET_DEFENDER    true で Defender を強制的に Free に戻す (false)
#                     ★サブスク全体に影響。通常は不要（既定はロールバック方式）
#   DFS_STATE_DIR     ロールバック状態の保存先         (~/.dfs-priv)
#   AUTO_APPROVE      確認プロンプトをスキップ    (false)
#
# 既定動作: setup が保存した「変更前のプラン状態」へ Defender を復元する（ロールバック）。
#           保存状態が無ければ Defender 設定には一切触れない。
#
set -euo pipefail

RESOURCE_GROUP="${RESOURCE_GROUP:-rg-defender-priv-vm}"
SUBSCRIPTION_ID="${SUBSCRIPTION_ID:-}"
RESET_DEFENDER="${RESET_DEFENDER:-false}"
DFS_STATE_DIR="${DFS_STATE_DIR:-$HOME/.dfs-priv}"
AUTO_APPROVE="${AUTO_APPROVE:-false}"

log()  { printf '\033[1;34m[destroy]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; }

command -v az >/dev/null 2>&1 || { err "Azure CLI (az) が見つかりません。"; exit 1; }
az account show >/dev/null 2>&1 || { err "先に 'az login' を実行してください。"; exit 1; }

if [[ -n "$SUBSCRIPTION_ID" ]]; then
  az account set --subscription "$SUBSCRIPTION_ID"
fi

SUB_ID="$(az account show --query id -o tsv)"
DEFENDER_STATE_FILE="$DFS_STATE_DIR/defender-pricing-${SUB_ID}.env"

# Defender プランを指定の状態に設定するヘルパ
set_pricing() {
  local tier="$1" sub="$2"
  if [[ "$tier" == "Free" || -z "$sub" ]]; then
    az security pricing create --name VirtualMachines --tier "$tier" >/dev/null
  else
    az security pricing create --name VirtualMachines --tier "$tier" --subplan "$sub" >/dev/null
  fi
}

if ! az group show --name "$RESOURCE_GROUP" >/dev/null 2>&1; then
  warn "リソースグループ '$RESOURCE_GROUP' が見つかりません。スキップします。"
else
  warn "リソースグループ '$RESOURCE_GROUP' とその中の全リソースを削除します。"
  if [[ "$AUTO_APPROVE" != "true" ]]; then
    read -r -p "本当に削除しますか? [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]] || { log "中止しました。"; exit 0; }
  fi
  log "リソースグループを削除中..."
  az group delete --name "$RESOURCE_GROUP" --yes
  log "削除しました。"
fi

if [[ "$RESET_DEFENDER" == "true" ]]; then
  # 明示指定: 強制的に Free へ（サブスク全体に影響）
  warn "RESET_DEFENDER=true: Defender for Servers を強制的に Free に戻します。★サブスク全体に影響します。"
  if [[ "$AUTO_APPROVE" != "true" ]]; then
    read -r -p "強制的に Free に戻しますか? [y/N] " ans
    [[ "$ans" =~ ^[Yy]$ ]] || { log "Defender 設定は変更しません。"; exit 0; }
  fi
  set_pricing Free ""
  rm -f "$DEFENDER_STATE_FILE"
  log "Defender for Servers を Free に設定しました。"
elif [[ -f "$DEFENDER_STATE_FILE" ]]; then
  # 既定: setup 実行前の状態へロールバック
  saved_tier="$(grep '^tier=' "$DEFENDER_STATE_FILE" | cut -d= -f2-)"
  saved_sub="$(grep '^subplan=' "$DEFENDER_STATE_FILE" | cut -d= -f2-)"
  read -r cur_tier cur_sub < <(az security pricing show --name VirtualMachines --query '[pricingTier, subPlan]' -o tsv 2>/dev/null || true)

  if [[ "$saved_tier" == "$cur_tier" && "$saved_sub" == "$cur_sub" ]]; then
    log "Defender は既に元の状態（tier=$saved_tier subplan=${saved_sub:-(none)}）です。変更不要。"
    rm -f "$DEFENDER_STATE_FILE"
  else
    warn "Defender for Servers を setup 実行前の状態へ復元します:"
    warn "  現在: tier=${cur_tier:-?} subplan=${cur_sub:-(none)} -> 復元: tier=$saved_tier subplan=${saved_sub:-(none)}"
    if [[ "$AUTO_APPROVE" != "true" ]]; then
      read -r -p "この状態に復元しますか? [y/N] " ans
      [[ "$ans" =~ ^[Yy]$ ]] || { log "Defender 設定は変更しません（状態ファイルは保持）。"; exit 0; }
    fi
    set_pricing "$saved_tier" "$saved_sub"
    rm -f "$DEFENDER_STATE_FILE"
    log "Defender for Servers を tier=$saved_tier subplan=${saved_sub:-(none)} に復元しました。"
  fi
else
  warn "ロールバック用の保存状態がありません（${DEFENDER_STATE_FILE}）。"
  warn "Defender 設定はそのまま維持します。強制的に Free にするには RESET_DEFENDER=true を指定してください。"
fi
